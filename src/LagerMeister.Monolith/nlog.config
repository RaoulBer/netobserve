<?xml version="1.0" encoding="utf-8" ?>
<!--
  NLog configuration WITH trace correlation.
  Half of the NLog->OTel bridge: TraceId/SpanId from the ambient Activity are rendered
  into every file/console line via the ${activity} layout renderer (NLog 5.x built-in),
  so the "existing logging investment" stays correlated to the distributed trace even
  though it never touches OTLP. The other half (OTLP export -> Loki) is the OpenTelemetry
  logging provider wired in Program.cs. See docs/NLOG-BRIDGE.md.
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

  <!-- Registers the ${activity} layout renderer (TraceId/SpanId from Activity.Current). -->
  <extensions>
    <add assembly="NLog.DiagnosticSource" />
  </extensions>

  <targets>
    <target xsi:type="Console" name="console"
            layout="${longdate}|${level:uppercase=true}|trace=${activity:property=TraceId}|span=${activity:property=SpanId}|${logger}|${message} ${exception:format=tostring}" />
    <target xsi:type="File" name="file"
            fileName="${basedir}/logs/lagermeister.log"
            layout="${longdate}|${level:uppercase=true}|trace=${activity:property=TraceId}|span=${activity:property=SpanId}|${logger}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Quiet the framework's noisy Info logs; keep app logs. -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>
</nlog>
