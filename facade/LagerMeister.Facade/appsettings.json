{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "inventory-item-detail": {
        "ClusterId": "inventory",
        "Order": 1,
        "Match": { "Path": "/api/items/{id}" }
      },
      "monolith-catchall": {
        "ClusterId": "monolith",
        "Order": 2,
        "Match": { "Path": "/api/{**catch-all}" }
      }
    },
    "Clusters": {
      "inventory": {
        "Destinations": {
          "primary": { "Address": "http://inventory:8080/" }
        }
      },
      "monolith": {
        "Destinations": {
          "primary": { "Address": "http://monolith:8080/" }
        }
      }
    }
  }
}
